# Copy to .env and adjust. All keys are prefixed BRIDGE_RAG_.

# Profile: dev (laptop/CPU, tiny weights, every interface exercised) or prod.
BRIDGE_RAG_PROFILE_NAME=dev

# Bridge family per seam.
BRIDGE_RAG_BRIDGE_AB=attention
BRIDGE_RAG_BRIDGE_BC=gated

# Information-bottleneck loss (Eq.8). MINE stays diagnostic-only.
BRIDGE_RAG_REGULARIZER=l1
BRIDGE_RAG_LAMBDA_AB=0.001
BRIDGE_RAG_LAMBDA_BC=0.001
BRIDGE_RAG_BETA=1.0
BRIDGE_RAG_ENABLE_MINE_DIAGNOSTIC=false

# LR partitioning (Stabilizer 4).
BRIDGE_RAG_LR_FA=0.00001
BRIDGE_RAG_LR_GAB=0.0001
BRIDGE_RAG_LR_FC=0.0001
BRIDGE_RAG_LR_GBC=0.001
BRIDGE_RAG_GRAD_CLIP_NORM=1.0

BRIDGE_RAG_CORPUS_PATH=data/corpus.jsonl
BRIDGE_RAG_INDEX_PATH=data/corpus.faiss
